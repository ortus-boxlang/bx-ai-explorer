// Use aiModel() to pin the agent to a specific provider and model
model = aiModel(
    provider: "claude",
    params  : {
        model      : "claude-3-5-sonnet-20241022",
        temperature: 0.8,
        max_tokens : 1000
    }
)

// Creative writing agent configured for Claude's strengths
writerAgent = aiAgent(
    name        : "CreativeWriter",
    description : "A creative writing agent that crafts vivid, engaging short stories",
    instructions: "You are a talented sci-fi short story writer. Create vivid, engaging stories with strong characters, clear conflicts, and satisfying resolutions. Use sensory details and dialogue. Keep stories under 300 words.",
    model       : model
)

story = writerAgent.run( "Write a short story about an AI debugging assistant in a futuristic tech company." )
println( story )
