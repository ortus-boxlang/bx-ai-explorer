*/

// Build a reusable translation pipeline with template variables
translationPipeline = aiMessage()
    .user( "Translate this text to ${language}. Return ONLY the translation:\n\n${text}" )
    .toDefaultModel()
    .transform( (response) => response.content.trim() )

// Reuse the same pipeline for multiple languages
languages = [ "Spanish", "French", "German" ]
text      = "Hello! I am learning BoxLang and it is amazing."

println( "=== Translation Pipeline ===" )
for ( lang in languages ) {
    result = translationPipeline.run({ text: text, language: lang })
    println( lang.lJustify( 8 ) & ": " & result )
}

// Pipeline with a custom post-processing transform
wordCountPipeline = aiMessage()
    .user( "Write a one-sentence summary of BoxLang's main benefit." )
    .toDefaultModel()
    .transform( (response) => response.content.trim().listLen( " " ) )

println( "" )
println( "=== Word count from transform ===" )
count = wordCountPipeline.run( {} )
println( "Word count: " & count )
