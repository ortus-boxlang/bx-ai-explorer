// The "webSearch@bxai" string references the built-in web search tool
researchAgent = aiAgent(
    name        : "ResearchAssistant",
    description : "An AI research assistant with real-time web access",
    instructions: "Use web search to find current, accurate information. Always cite what you found.",
    tools       : [ "webSearch@bxai" ]
)

answer = researchAgent.run( "What are the latest features in BoxLang AI? Give me the most recent release notes." )
println( answer )
