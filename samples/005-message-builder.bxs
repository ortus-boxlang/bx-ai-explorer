// Compose a structured prompt using the fluent message builder
message = aiMessage()
    .system( "You are a senior BoxLang code reviewer. Be specific, constructive, and use emoji for clarity." )
    .user( "Please review this BoxLang function and suggest improvements:" )
    .user( "function greet( name ) { return 'Hello, ' & name & '!' }" )

answer = aiChat( message.getMessages() )
println( answer )
