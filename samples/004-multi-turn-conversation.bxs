// Build the conversation history manually
messages = [
    {
        role   : "system",
        content: "You are a friendly BoxLang instructor. Keep answers concise and use examples."
    },
    {
        role   : "user",
        content: "What is BoxLang?"
    },
    {
        role   : "assistant",
        content: "BoxLang is a modern, dynamic JVM language from Ortus Solutions. It brings CFML-style productivity to the Java platform, great for web apps, CLIs, and APIs."
    },
    {
        role   : "user",
        content: "What data types does it support?"
    }
]

answer = aiChat( messages, {}, { provider: "gemini" } )
println( answer )
