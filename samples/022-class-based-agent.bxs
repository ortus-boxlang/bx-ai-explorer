// Instantiate and use the class-based agent
agent    = new agents.OrderSupportAgent()
response = agent.run( "What's the status of order ORD-77123?" )
println( response )

// Test the agent configuration
config = agent.getConfig()
println( "" )
println( "Agent: " & config.name & " | Tools: " & config.toolCount )
